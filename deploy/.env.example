# Copy to deploy/.env and fill values. Never commit .env.

DOMAIN=example.com
PUBLIC_APP_URL=https://example.com

POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres
POSTGRES_USER=postgres

# From self-hosted Supabase (JWT keys must match JWT_SECRET)
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters
ANON_KEY=
SERVICE_ROLE_KEY=
SUPABASE_URL=https://example.com/supabase
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=https://example.com/supabase
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=local

CRON_SECRET=
PRICE_RELAY_SECRET=
EXCHANGE_ENCRYPTION_KEY=
TELEGRAM_SESSION_ENC_KEY=
PLATFORM_SECRETS_KEY=
PAYMENT_WEBHOOK_SECRET=

# Optional
NOWPAYMENTS_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=Hermes <noreply@example.com>
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
AI_API_KEY=
AI_GATEWAY_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL=google/gemini-2.0-flash-001

VITE_BRAND_NAME=Hermes
RELAY_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
CRON_INTERVAL_SEC=10

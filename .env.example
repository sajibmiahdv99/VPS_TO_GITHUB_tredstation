# Local development (never commit real .env)

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=local

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=dev-cron-secret
PRICE_RELAY_SECRET=dev-relay-secret
EXCHANGE_ENCRYPTION_KEY=dev-exchange-key-change-me
TELEGRAM_SESSION_ENC_KEY=dev-telegram-key-change-me
PLATFORM_SECRETS_KEY=dev-platform-key-change-me
PAYMENT_WEBHOOK_SECRET=dev-payment-secret

# Optional
AI_API_KEY=
AI_GATEWAY_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL=google/gemini-2.0-flash-001
RESEND_API_KEY=
EMAIL_FROM=AGENT TRED <onboarding@resend.dev>
BRAND_NAME=AGENT TRED
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
SENTRY_DSN=

# Super-admin hardening (optional)
# Comma-separated IPs allowed for /sadmin mutations (empty = allow all)
SADMIN_IP_ALLOWLIST=
# Require MFA AAL2 for super admin UI (default 1)
SADMIN_REQUIRE_MFA=1

# Telegram bot for notification delivery
TELEGRAM_BOT_TOKEN=

# HTTPS reverse proxy: set domain when using deploy/Caddyfile.production
DOMAIN=
